# Required: DeepSeek API key
DEEPSEEK_API_KEY=sk-...

# Optional: Moonshot API key
MOONSHOT_API_KEY=sk-...

# Required: GitHub token for repo access
GH_TOKEN=ghp_...

# Required: Password for opencode server access
OPENCODE_SERVER_PASSWORD=...

# Required: Domain for this service (e.g., opencode.dokploy.boronine.com)
DOMAIN=opencode.dokploy.boronine.com
